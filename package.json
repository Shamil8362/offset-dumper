{
  "name": "offset-dumper-gui",
  "version": "1.0.0",
  "description": "Offset Dumper GUI — Windows x64 memory analysis tool",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder --win --x64",
    "build:dir": "vite build && electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.offsetdumper.gui",
    "productName": "OffsetDumper",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "backend/offset_backend.exe",
        "to": "offset_backend.exe"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
